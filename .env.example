# Cổng server backend
PORT=3001

# Bí mật ký JWT — đổi giá trị này ở môi trường thật
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Tài khoản admin khởi tạo (dùng cho `npm run seed` / `npm run reset-admin`)
ADMIN_EMAIL=admin@iid.org.vn
ADMIN_PASSWORD=change-me

# Origin của frontend cho CORS (khi không dùng vite proxy)
CORS_ORIGIN=http://localhost:5174
